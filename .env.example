APP_NAME=Ledgerline
# Production-safe defaults. For local development set APP_ENV=local and
# APP_DEBUG=true (debug pages leak stack traces, env and config — never in prod).
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: PostgreSQL only.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ledgerline
DB_USERNAME=ledgerline
DB_PASSWORD=

# Sessions, cache and queues are backed by Valkey (Redis-protocol compatible).
# The phpredis C extension is not required; we use the pure-PHP predis client.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Secure session cookies default to on in production. HSTS is emitted whenever
# this is true, so only leave it on for an HTTPS deployment.
# SESSION_SECURE_COOKIE=true

# If the app runs behind a TLS-terminating reverse proxy, list its address(es)
# so X-Forwarded-* is honoured (real HTTPS scheme → Secure cookies). Use '*' to
# trust all forwarding proxies (only safe when nothing untrusted can reach the
# app directly). Empty = trust none.
# TRUSTED_PROXIES=*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Path to the ffmpeg binary used for video thumbnails. On Laravel Cloud, run
# deploy/ffmpeg.sh as a build command and set this to the installed binary.
# GALLERY_FFMPEG_PATH=/var/www/bin/ffmpeg/ffmpeg

# Photo/video processing can take a while per item; the queue's retry window
# must exceed the worker --timeout or long jobs get retried mid-run. Keep this
# above the worker timeout (e.g. 700 for a 600s timeout).
REDIS_QUEUE_RETRY_AFTER=700

CACHE_STORE=redis
# CACHE_PREFIX=

# Valkey connection (wire-compatible with the Redis protocol).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Pocket-ID (OIDC/OAuth2 identity provider). Authentication is handled
# exclusively by Pocket-ID; the application has no local password login.
# POCKETID_BASE_URL is the OIDC issuer base URL of your Pocket-ID instance.
POCKETID_BASE_URL=https://id.example.com
POCKETID_CLIENT_ID=
POCKETID_CLIENT_SECRET=
POCKETID_REDIRECT_URI=http://localhost:8000/auth/callback
POCKETID_USE_PKCE=true
# Single-tenant sign-in gate. Leave both empty for "first user wins" (the first
# subject to authenticate claims the sole account; all others are rejected), or
# pin sign-in to explicit OIDC subject IDs and/or verified e-mails (comma lists).
# POCKETID_ALLOWED_SUBS=
# POCKETID_ALLOWED_EMAILS=

# File storage (S3-compatible object storage; MinIO locally, S3/R2/Hetzner/B2 in
# prod). Set FILES_DISK=files to store uploads on S3 instead of the local volume.
# Hetzner example: REGION=nbg1, ENDPOINT=https://nbg1.your-objectstorage.com,
# USE_PATH_STYLE=false (virtual-hosted; bucket name must be lowercase/DNS-safe).
FILES_DISK=local
FILES_S3_KEY=
FILES_S3_SECRET=
FILES_S3_REGION=us-east-1
FILES_S3_BUCKET=ledgerline-files
FILES_S3_ENDPOINT=http://127.0.0.1:9000
FILES_S3_USE_PATH_STYLE=true
# Integrity checksums: newer aws-sdk-php sends x-amz-checksum-* by default, which
# Hetzner/B2/some MinIO reject. Default "when_required" keeps them compatible.
# FILES_S3_CHECKSUM_CALCULATION=when_required
# FILES_S3_CHECKSUM_VALIDATION=when_required
# Maximum upload size in megabytes.
FILES_MAX_UPLOAD_MB=2048

VITE_APP_NAME="${APP_NAME}"

# Max paired mobile devices (oldest is revoked when a new one pairs beyond this)
PAIRING_MAX_DEVICES=3
