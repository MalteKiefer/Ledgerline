APP_NAME=Ledgerline
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: PostgreSQL only.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ledgerline
DB_USERNAME=ledgerline
DB_PASSWORD=

# Sessions, cache and queues are backed by Valkey (Redis-protocol compatible).
# The phpredis C extension is not required; we use the pure-PHP predis client.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

# Valkey connection (wire-compatible with the Redis protocol).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Pocket-ID (OIDC/OAuth2 identity provider). Authentication is handled
# exclusively by Pocket-ID; the application has no local password login.
# POCKETID_BASE_URL is the OIDC issuer base URL of your Pocket-ID instance.
POCKETID_BASE_URL=https://id.example.com
POCKETID_CLIENT_ID=
POCKETID_CLIENT_SECRET=
POCKETID_REDIRECT_URI=http://localhost:8000/auth/callback
POCKETID_USE_PKCE=true

VITE_APP_NAME="${APP_NAME}"
