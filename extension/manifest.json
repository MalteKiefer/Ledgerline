{
  "manifest_version": 3,
  "name": "Ledgerline",
  "version": "1.505.20",
  "description": "Zero-knowledge password autofill for your self-hosted Ledgerline.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "clipboardWrite", "idle", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": { "service_worker": "dist/background.js", "type": "module" },
  "icons": { "16": "icons/16.png", "32": "icons/32.png", "48": "icons/48.png", "128": "icons/128.png" },
  "action": { "default_popup": "dist/src/popup.html", "default_title": "Ledgerline", "default_icon": { "16": "icons/16.png", "32": "icons/32.png", "48": "icons/48.png" } },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content-loader.js"], "run_at": "document_idle", "all_frames": false },
    { "matches": ["<all_urls>"], "js": ["dist/passkey-inject.js"], "run_at": "document_start", "all_frames": false, "world": "MAIN" }
  ],
  "web_accessible_resources": [
    { "resources": ["dist/content.js", "dist/assets/*"], "matches": ["<all_urls>"] }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
