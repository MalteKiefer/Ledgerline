[
  {
    "name": "sorted keys + compact",
    "input": {
      "b": 1,
      "a": 2,
      "c": 3
    },
    "expected": "{\"a\":2,\"b\":1,\"c\":3}"
  },
  {
    "name": "nested + array order",
    "input": {
      "z": [
        3,
        1,
        2
      ],
      "a": {
        "y": 1,
        "x": 2
      }
    },
    "expected": "{\"a\":{\"x\":2,\"y\":1},\"z\":[3,1,2]}"
  },
  {
    "name": "null/bool/int",
    "input": {
      "n": null,
      "t": true,
      "f": false,
      "i": -7
    },
    "expected": "{\"f\":false,\"i\":-7,\"n\":null,\"t\":true}"
  },
  {
    "name": "dec-string lat/lng (no float)",
    "input": {
      "lat": "52.520008",
      "lng": "13.404954"
    },
    "expected": "{\"lat\":\"52.520008\",\"lng\":\"13.404954\"}"
  },
  {
    "name": "unicode NFC + minimal escape",
    "input": {
      "key": "a\"b\\cé"
    },
    "expected": "{\"key\":\"a\\\"b\\\\cé\"}"
  },
  {
    "name": "empty object/array",
    "input": {
      "o": {},
      "a": []
    },
    "expected": "{\"a\":[],\"o\":{}}"
  }
]
